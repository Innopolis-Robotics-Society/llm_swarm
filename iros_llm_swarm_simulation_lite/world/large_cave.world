# ============================================================
# Dungeon для 20 роботов
# Stage world file for LLM-controlled multi-robot warehouse
# ============================================================

# Параметры симуляции
resolution 0.05          # метров/пиксель (совпадает с картой)
interval_sim 100         # шаг симуляции в мс (100мс = 10 Гц обновлений)

# Окно отображения (можно убрать для headless)
window
(
  size [ 800 800 ]       # размер окна в пикселях
  scale 20.0             # масштаб (пикселей/метр)
  center [ 15.0 15.0 ]   # центр вида (м)
  rotate [ 0.0 0.0 ]
  show_data 1            # показывать данные сенсоров
)

# Загрузка модели робота
include "warehouse_robot.inc"

# Карта мира (та же, что и для Nav2)
define floorplan model
(
  color "gray30"
  boundary 1
  gui_nose 0
  gui_grid 0
  gui_outline 0
  gripper_return 0
  fiducial_return 0
  ranger_return 1.0
)

floorplan
(
  name "large_cave"
  bitmap "cave.pgm"
  size [ 150.0 150.0 0.5 ]  # физический размер мира (м)
  pose [ 0.0 0.0 0.0 0.0 ]
)

# ============================================================
# 20 роботов — позиции в зоне загрузки/разгрузки
# Координаты: x y z heading(°)
# ============================================================

# Зона 1: Кривозубая челядь

warehouse_robot ( name "robot_0"  pose [  -37.0  58.5 0.0  0.0 ] color "cyan" )
warehouse_robot ( name "robot_1"  pose [  -35.5  60.0 0.0  0.0 ] color "cyan" )
warehouse_robot ( name "robot_2"  pose [  -37.0  60.0 0.0  0.0 ] color "cyan" )
warehouse_robot ( name "robot_3"  pose [  -35.5  58.5 0.0  0.0 ] color "cyan" )

# Зона 2: На пути в ад

warehouse_robot ( name "robot_4"  pose [  -38.0  -9.0 0.0  0.0 ] color "magenta" )
warehouse_robot ( name "robot_5"  pose [  -36.5  -9.0 0.0  0.0 ] color "magenta" )
warehouse_robot ( name "robot_6"  pose [  -38.0  -10.5 0.0  0.0 ] color "magenta" )
warehouse_robot ( name "robot_7"  pose [  -36.5  -10.5 0.0  0.0 ] color "magenta" )

# Зона 3: Каморка гоблина

warehouse_robot ( name "robot_8" pose [ 62.0 26.5 0.0 0.0 ] color "green" )
warehouse_robot ( name "robot_9" pose [ 63.5 26.5 0.0 0.0 ] color "green" )
warehouse_robot ( name "robot_10" pose [ 62.0 28.0 0.0 0.0 ] color "green" )
warehouse_robot ( name "robot_11" pose [ 63.5 28.0 0.0 0.0 ] color "green" )

# Зона 4: Жертвенный зал

warehouse_robot ( name "robot_12" pose [ 8.0 -15.0 0.0 180.0 ] color "orange" )
warehouse_robot ( name "robot_13" pose [ 9.5 -15.0 0.0 180.0 ] color "orange" )
warehouse_robot ( name "robot_14" pose [ 8.0 -16.5 0.0 180.0 ] color "orange" )
warehouse_robot ( name "robot_15" pose [ 9.5 -16.5 0.0 180.0 ] color "orange" )

# Зона 5: У туалета

warehouse_robot ( name "robot_16" pose [ 27.0 26.5 0.0 0.0 ] color "yellow" )
warehouse_robot ( name "robot_17" pose [ 28.5 26.5 0.0 0.0 ] color "yellow" )
warehouse_robot ( name "robot_18" pose [ 27.0 28.0 0.0 0.0 ] color "yellow" )
warehouse_robot ( name "robot_19" pose [ 28.5 28.0 0.0 0.0 ] color "yellow" )