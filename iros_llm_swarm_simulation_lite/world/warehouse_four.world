# ============================================================
# Складской мир для 20 роботов
# Stage world file for LLM-controlled multi-robot warehouse
# ============================================================

# Параметры симуляции
resolution 0.05          # метров/пиксель (совпадает с картой)
interval_sim 100         # шаг симуляции в мс (100мс = 10 Гц обновлений)

# Окно отображения (можно убрать для headless)
window
(
  size [ 800 800 ]       # размер окна в пикселях
  scale 20.0             # масштаб (пикселей/метр)
  center [ 15.0 15.0 ]   # центр вида (м)
  rotate [ 0.0 0.0 ]
  show_data 1            # показывать данные сенсоров
)

# Загрузка модели робота
include "warehouse_robot.inc"

# Карта мира (та же, что и для Nav2)
define floorplan model
(
  color "gray30"
  boundary 1
  gui_nose 0
  gui_grid 0
  gui_outline 0
  gripper_return 0
  fiducial_return 0
  ranger_return 1.0
)

floorplan
(
  name "warehouse"
  bitmap "warehouse.pgm"
  size [ 30.0 30.0 0.5 ]  # физический размер мира (м)
  pose [ 15.0 15.0 0.0 0.0 ]
)

# ============================================================
# 20 роботов — позиции в зоне загрузки/разгрузки
# Координаты: x y z heading(°)
# ============================================================

# Зона 1: Левый нижний угол — 5 роботов
warehouse_robot ( name "robot_0"  pose [  2.0  2.0 0.0   0.0 ] color "orange" )
warehouse_robot ( name "robot_1"  pose [  3.5  2.0 0.0   0.0 ] color "orange" )
warehouse_robot ( name "robot_2"  pose [  2.0  3.5 0.0   0.0 ] color "orange" )
warehouse_robot ( name "robot_3"  pose [  3.5  3.5 0.0   0.0 ] color "orange" )
warehouse_robot ( name "robot_4"  pose [  2.0  5.0 0.0   0.0 ] color "orange" )

# Зона 2: Правый нижний угол — 5 роботов
warehouse_robot ( name "robot_5"  pose [ 26.0  2.0 0.0 180.0 ] color "magenta" )
warehouse_robot ( name "robot_6"  pose [ 27.5  2.0 0.0 180.0 ] color "magenta" )
warehouse_robot ( name "robot_7"  pose [ 26.0  3.5 0.0 180.0 ] color "magenta" )
warehouse_robot ( name "robot_8"  pose [ 27.5  3.5 0.0 180.0 ] color "magenta" )
warehouse_robot ( name "robot_9"  pose [ 27.5  5.0 0.0 180.0 ] color "magenta" )

# Зона 3: Левый верхний угол — 5 роботов
warehouse_robot ( name "robot_10" pose [  2.0 28.0 0.0   0.0 ] color "cyan" )
warehouse_robot ( name "robot_11" pose [  3.5 28.0 0.0   0.0 ] color "cyan" )
warehouse_robot ( name "robot_12" pose [  2.0 26.5 0.0   0.0 ] color "cyan" )
warehouse_robot ( name "robot_13" pose [  3.5 26.5 0.0   0.0 ] color "cyan" )
warehouse_robot ( name "robot_14" pose [  2.0 25.0 0.0   0.0 ] color "cyan" )

# Зона 4: Правый верхний угол — 5 роботов
warehouse_robot ( name "robot_15" pose [ 26.0 28.0 0.0 180.0 ] color "blue" )
warehouse_robot ( name "robot_16" pose [ 27.5 28.0 0.0 180.0 ] color "blue" )
warehouse_robot ( name "robot_17" pose [ 26.0 26.5 0.0 180.0 ] color "blue" )
warehouse_robot ( name "robot_18" pose [ 27.5 26.5 0.0 180.0 ] color "blue" )
warehouse_robot ( name "robot_19" pose [ 27.5 25.0 0.0 180.0 ] color "blue" )