# ============================================================
# The Skeld (Among Us) для 20 роботов
# Stage world file for LLM-controlled multi-robot warehouse
# ============================================================

# Параметры симуляции
resolution 0.05          # метров/пиксель (совпадает с картой)
interval_sim 100         # шаг симуляции в мс (100мс = 10 Гц обновлений)

# Окно отображения (можно убрать для headless)
window
(
  size [ 1200 700 ]      # размер окна в пикселях (~66.6×37.75 м карта)
  scale 18.0             # масштаб (пикселей/метр)
  center [ 0.0 0.0 ]     # центр карты в мировых координатах (м)
  rotate [ 0.0 0.0 ]
  show_data 1            # показывать данные сенсоров
)

# Загрузка модели робота
include "warehouse_robot.inc"

# Карта мира (та же, что и для Nav2)
define floorplan model
(
  color "gray30"
  boundary 1
  gui_nose 0
  gui_grid 0
  gui_outline 0
  gripper_return 0
  fiducial_return 0
  ranger_return 1.0
)

floorplan
(
  name "amongus"
  bitmap "amongus.pgm"
  size [ 66.6 37.75 0.5 ]  # физический размер мира (м)
  pose [ 0.0 0.0 0.0 0.0 ]
)

# ============================================================
# 20 роботов — 5 групп по 4 в разных отсеках Skeld
# Каждая группа: 2×2 сетка, шаг 1.5 м, центр = home из YAML
# Координаты: x y z heading(°)
# ============================================================

# Группа 1: cyan @ Верхний двигатель (Upper Engine)
warehouse_robot ( name "robot_0"  pose [ -22.65   9.15 0.0    0.0 ] color "cyan" )
warehouse_robot ( name "robot_1"  pose [ -21.15   9.15 0.0    0.0 ] color "cyan" )
warehouse_robot ( name "robot_2"  pose [ -22.65  10.65 0.0    0.0 ] color "cyan" )
warehouse_robot ( name "robot_3"  pose [ -21.15  10.65 0.0    0.0 ] color "cyan" )

# Группа 2: magenta @ Электрика (Electrical)
warehouse_robot ( name "robot_4"  pose [  -9.45  -6.65 0.0    0.0 ] color "magenta" )
warehouse_robot ( name "robot_5"  pose [  -7.95  -6.65 0.0    0.0 ] color "magenta" )
warehouse_robot ( name "robot_6"  pose [  -9.45  -5.15 0.0    0.0 ] color "magenta" )
warehouse_robot ( name "robot_7"  pose [  -7.95  -5.15 0.0    0.0 ] color "magenta" )

# Группа 3: green @ Навигация (Navigation, дальний восток)
warehouse_robot ( name "robot_8"  pose [  27.75   1.15 0.0  180.0 ] color "green" )
warehouse_robot ( name "robot_9"  pose [  29.25   1.15 0.0  180.0 ] color "green" )
warehouse_robot ( name "robot_10" pose [  27.75   2.65 0.0  180.0 ] color "green" )
warehouse_robot ( name "robot_11" pose [  29.25   2.65 0.0  180.0 ] color "green" )

# Группа 4: orange @ Хранилище (Storage)
warehouse_robot ( name "robot_12" pose [  -0.15 -11.65 0.0    0.0 ] color "orange" )
warehouse_robot ( name "robot_13" pose [   1.35 -11.65 0.0    0.0 ] color "orange" )
warehouse_robot ( name "robot_14" pose [  -0.15 -10.15 0.0    0.0 ] color "orange" )
warehouse_robot ( name "robot_15" pose [   1.35 -10.15 0.0    0.0 ] color "orange" )

# Группа 5: yellow @ Оружейная (Weapons)
warehouse_robot ( name "robot_16" pose [  16.85   9.95 0.0  180.0 ] color "yellow" )
warehouse_robot ( name "robot_17" pose [  18.35   9.95 0.0  180.0 ] color "yellow" )
warehouse_robot ( name "robot_18" pose [  16.85  11.45 0.0  180.0 ] color "yellow" )
warehouse_robot ( name "robot_19" pose [  18.35  11.45 0.0  180.0 ] color "yellow" )
