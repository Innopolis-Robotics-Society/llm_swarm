Panels:
  - Class: rviz_common/Displays
    Help Height: 0
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /Status1
        - /Map1/Topic1
        - /Map3/Topic1
        - /MarkerArray4/Topic1
      Splitter Ratio: 0.5
    Tree Height: 631
  - Class: rviz_common/Selection
    Name: Selection
  - Class: rviz_common/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
  - Class: rviz_common/Time
    Experimental: false
    Name: Time
    SyncMode: 0
    SyncSource: LaserScan
  - Class: iros_llm_rviz_panel/LLM-Panel
    Name: LLM-Panel
    map_name: cave
    preview_mode: false
    tab_index: 0
  - Class: rviz_common/Tool Properties
    Expanded:
      - /Place Obstacle1
    Name: Tool Properties
    Splitter Ratio: 0.5
