+        return {}
+    slim: dict = {}
+    for key in (
+        'timestamp', 'source', 'warnings', 'failure_summary',
+        'bt_state', 'formations', 'robots', 'recent_events',
+    ):
+        if key in snapshot:
+            slim[key] = snapshot[key]
