        <Sequence name="SwarmMission">
            <MapfPlan
                robot_ids_csv="{robot_ids_csv}"
                goal_x="{goal_x}"
                goal_y="{goal_y}"
                goal_spacing="1.0"
                mapf_ok="{mapf_ok}"
                mapf_info="{mapf_info}"/>
        </Sequence>
    </BehaviorTree>
</root>