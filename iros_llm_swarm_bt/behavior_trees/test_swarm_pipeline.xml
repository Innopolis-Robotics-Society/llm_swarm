<root BTCPP_format="4" main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <Sequence name="SwarmPipeline">
      <MapfPlan 
        robot_ids_csv="{robot_ids_csv}" 
        goal_x="{goal_x}" 
        goal_y="{goal_y}" 
        mapf_ok="{mapf_ok}" 
        mapf_info="{mapf_info}"/>

      <SetFormation 
        formation_id="{formation_id}" 
        leader_ns="{leader_ns}" 
        follower_ns_csv="{follower_ns_csv}" 
        offsets_x_csv="{offsets_x_csv}" 
        offsets_y_csv="{offsets_y_csv}" 
        activate="{activate}" 
        formation_enabled="{formation_enabled}" 
        active_formation="{active_formation}"/>
    </Sequence>
  </BehaviorTree>
</root>