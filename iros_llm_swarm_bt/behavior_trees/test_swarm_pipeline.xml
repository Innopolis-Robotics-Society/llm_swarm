<!-- Kept for reference — main tree is swarm_navigate_to_pose.xml -->
<root BTCPP_format="4" main_tree_to_execute="TestPipeline">
  <BehaviorTree ID="TestPipeline">
    <ReactiveFallback>
      <Sequence>
        <CheckMode mode="{@mode}" expected="mapf"/>
        <MapfPlan
          robot_ids="{@robot_ids}"
          goals="{@goals}"
          mapf_ok="{@mapf_ok}"
          mapf_info="{@mapf_info}"/>
      </Sequence>
      <Sequence>
        <CheckMode mode="{@mode}" expected="formation"/>
        <SetFormation
          formation_id="{@formation_id}"
          leader_ns="{@leader_ns}"
          follower_ns="{@follower_ns}"
          offsets_x="{@offsets_x}"
          offsets_y="{@offsets_y}"
          activate="true"
          formation_enabled="{@formation_enabled}"
          active_formation="{@active_formation}"/>
      </Sequence>
    </ReactiveFallback>
  </BehaviorTree>
</root>